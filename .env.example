# --- Auth (optional) ---
# If set, the service requires Authorization: Bearer <token> on all
# endpoints except /health. Leave blank to disable.
MEMORY_AUTH_TOKEN=

# --- OpenRouter (one key for all providers — recommended) ---
# https://openrouter.ai/keys
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# --- Models (OpenRouter slugs) ---
# Embedding: Gemini Embedding 2 (preview), MRL-truncated to EMBEDDING_DIM.
EMBEDDING_MODEL=google/gemini-embedding-2-preview
EMBEDDING_DIM=1536

# Extraction LLM: GPT-5.4 mini for structured-output extraction +
# reconciliation + LLM judge. Alternatives: openai/gpt-5.4, anthropic/claude-haiku-4-5.
EXTRACTION_MODEL=openai/gpt-5.4-mini

# Reranker: Jina Reranker v3 via direct API (sharper scores on
# personal-fact corpora than Cohere — BEIR nDCG-10 61.94).
# Alternative providers: cohere (direct), openrouter (cohere via gateway).
RERANKER_PROVIDER=jina
RERANKER_MODEL=jina-reranker-v3

# --- Optional direct-vendor keys (only if you bypass OpenRouter) ---
# These are read only when the matching `*_PROVIDER` is set to the
# vendor's own name (e.g. EMBEDDING_PROVIDER=gemini → uses GOOGLE_API_KEY).
# By default everything routes through OPENROUTER_API_KEY.
GOOGLE_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
JINA_API_KEY=
COHERE_API_KEY=

# --- Optional provider override ---
# Reranker uses jina (direct) by default; embedding and extraction
# default to openrouter. Set *_PROVIDER=direct or to a specific name
# (jina, cohere, openrouter) to override.
EMBEDDING_PROVIDER=openrouter
EXTRACTION_PROVIDER=openrouter

# --- Logging ---
LOG_LEVEL=INFO
